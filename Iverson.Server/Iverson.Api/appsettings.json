{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Kestrel": {
    "Endpoints": {
      "Grpc": {
        "Url": "http://*:8080",
        "Protocols": "Http2"
      },
      "Http": {
        "Url": "http://*:8081",
        "Protocols": "Http1"
      }
    }
  },
  "ConnectionStrings": {
    "Postgres": "Host=postgres;Port=5432;Database=iverson;Username=iverson;Password=iverson",
    "StarRocks": "Server=starrocks;Port=9030;Database=iverson;Uid=root;Pwd=;AllowPublicKeyRetrieval=true;"
  },
  "Elasticsearch": {
    "Url": "http://elasticsearch:9200"
  },
  "Qdrant": {
    "Host": "qdrant",
    "Port": "6334"
  },
  "Kafka": {
    "BootstrapServers": "kafka:9092"
  },
  "Otel": {
    "Endpoint": "http://jaeger:4317"
  }
}
